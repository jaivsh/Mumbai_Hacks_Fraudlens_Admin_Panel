# =============================================================================
# FraudLens Admin Dashboard — environment template
# =============================================================================
# Copy to `.env` for local dev:  cp .env.example .env
#
# Create React App (CRA) reads REACT_APP_* ONLY at **build** time (npm run build).
# Cloud Run / CI must inject these before `npm run build` — they are NOT read at
# runtime from the server. Missing vars → blank strings in the bundle (Scribe,
# Assistant, Fraud API, etc. break silently or with UI errors).
#
# Secrets note: anything prefixed REACT_APP_ is exposed in the browser bundle.
# Prefer backend proxies for highly sensitive keys in future refactors.
# =============================================================================

# ----- Firebase (required for auth + Firestore) -----
# Firebase Console → Project settings → Your apps → Web app config
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
# Optional (Analytics)
REACT_APP_FIREBASE_MEASUREMENT_ID=

# ----- Chronos (GCS document upload / stored report copy) -----
# Cloud Run or VM base URL, no trailing slash. Used by Scribe + hash verification flows.
REACT_APP_CHRONOS_API=
# Optional: if you use a VM URL instead of / in addition to Cloud Run
REACT_APP_CHRONOS_API_URL=

# ----- Fraud scoring API (Cloud Run) -----
REACT_APP_FRAUD_API_URL=

# ----- Scribe (Gemini report generation in browser) -----
# Required for generate report. Get a key: https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=
# Optional; default in code: models/gemini-2.5-flash
# REACT_APP_GEMINI_MODEL=models/gemini-2.5-flash

# Scribe PDF/report branding (optional; sensible defaults in reportFormats.js)
REACT_APP_SCRIBE_ORG_NAME=
REACT_APP_SCRIBE_LOGO_URL=
REACT_APP_SCRIBE_DPO_NAME=
REACT_APP_SCRIBE_DPO_EMAIL=
REACT_APP_SCRIBE_DPO_PHONE=
REACT_APP_SCRIBE_CONTACT_EMAIL=

# ----- Assistant API (chat + WebSocket live tab) -----
REACT_APP_ASSISTANT_API=
# Production: false. Lab only: true with local assistant_api REQUIRE_AUTH=false
REACT_APP_ASSISTANT_ALLOW_DEMO=false

# ----- Optional: one-click demo login buttons (users must exist in Firebase) -----
# REACT_APP_DEMO_IT_EMAIL=
# REACT_APP_DEMO_IT_PASSWORD=
# REACT_APP_DEMO_EXEC_EMAIL=
# REACT_APP_DEMO_EXEC_PASSWORD=
